{
  "name": "agents-markdown",
  "version": "0.1.0",
  "description": "TypeScript SDK and CLI for generating and safely maintaining AGENTS.md guardrails.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Molten-Bot/agents-markdown.git"
  },
  "bugs": {
    "url": "https://github.com/Molten-Bot/agents-markdown/issues"
  },
  "homepage": "https://github.com/Molten-Bot/agents-markdown#readme",
  "type": "module",
  "bin": {
    "agents-md": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./patterns": {
      "types": "./dist/patterns.d.ts",
      "import": "./dist/patterns.js"
    }
  },
  "files": [
    "dist/",
    "patterns/",
    "AGENT_GUIDE.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "sync:patterns": "node scripts/sync-patterns.mjs",
    "build:release": "npm run sync:patterns && npm run build",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build:release && node --test tests/*.test.mjs",
    "coverage": "npm run build:release && node --test --experimental-test-coverage --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 --test-coverage-include='dist/**/*.js' tests/*.test.mjs",
    "prepack": "npm run build:release"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
